# ~/.zshenv
# $XDG_CONFIG_HOME/tmux/tmux.conf

# for tmux
typeset -U path PATH
export TERM=xterm-256color
setopt interactive_comments

# 現在は設計中のため一緒にリロード。削除予定
source ~/.zshenv

setopt no_beep
setopt IGNORE_EOF

## util
function green() {
  print "\033[1;32m$*\033[0m"
}

function yellow() {
  print "\033[1;33m$*\033[0m"
}

function copy-line() {
  echo -n $BUFFER | clip.exe
}
zle -N copy-line

function co() { # edit zshrc
    nvim $ZDOTDIR/.zshrc

    # arge -eq 'tmux'
    # nvim $XDG_CONFIG_HOME/tmux/tmux.conf
}
function so() { # reload zshrc
	source $ZDOTDIR/.zshrc
	green "reload .zshrc"
}

# chezmoi add
function dotpush() {
	# 更新されたファイルを 1つ取得
	chezmoi status | head -n 1 | sed 's/.../~\//' | read fn
	echo $fn
	chezmoi diff $fn --reverse  | tail -n +6 | batcat -l diff
	read
	# コミットして戻る (chezmoi cd からでは cd - 出来ない)
	chezmoi add $fn
	cd $HOME/.local/share/chezmoi
	git add -A && git commit
	cd -
}


# 現在時刻と天気
function sora() {
	echo ''
	python3 ~/sora.py
}

## keybind
# Ctrl = "^" or "\C-"
# Alt  = "^[" or "\e"

bindkey "^u" beginning-of-line      # HOME
bindkey "^d" backward-delete-char   # BS
bindkey "^k" up-line-or-history     # 上
# bindkey "^N" down-line-or-history # 下
bindkey "^h" backward-char          # 左
bindkey "^l" forward-char           # 右
bindkey "^z" undo                   # Undo
bindkey '^a' copy-line # cmd に入力中の文字列をコピー

bindkey "^b" backward-word
bindkey "^f" forward-word

## alias
alias ls=ls\ --color=auto
alias vi=nvim
### nvim を less 代わりに使う
alias vl=nvim\ -R
