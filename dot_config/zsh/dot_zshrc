function copy-line() {
    echo -n $BUFFER | iconv -f utf-8 -t utf-16le | sed '1s/^\xFF\xFE//' | ~/bin/clip.exe
    BUFFER=''
    zle reset-prompt
}

zle -N copy-line

dotstatus() {
    # get one modified file, except 'run_script.sh'
    # exclude run_script (grep -v '^ R')
    local fn
    chezmoi status | grep -v '^ R' | head -n 1 | sed 's/.../~\//' | read fn
    echo $fn
}

# chezmoi add -> git add -> git commit
function dotpush() {
    local fn=$(dotstatus)
    [[ "$fn" == "" ]] && green "not modified" && return 0

    chezmoi diff $fn --reverse  | tail -n +6 | batcat -l diff
    echo "Add and commit? [Enter to continue / q to quit]: "
    read -k ans # -k: read first char
    [[ "$ans" == "q" ]] && echo 'uit!' && return 0

    chezmoi add $fn
    cd $(chezmoi source-path)
    git add -A && git commit
    cd -
}

# cd $dotfiles with popup window
function _popup_dotfilesdir() {
    tmux display-popup \
        -w 80% \
        -h 80% \
        -E "cd "$(chezmoi source-path)" && $SHELL"
    }

function dot() {
    if tmux has; then
        _popup_dotfilesdir
    else
        tmux new-session -A -s main -c "$(chezmoi source-path)"
    fi
}

## keybind {{{
# Ctrl = "^" or "\C-"
# Alt  = "^[" or "\e"

bindkey "^u" beginning-of-line      # HOME
bindkey "^d" backward-delete-char   # BS
bindkey "^k" up-line-or-history     # 上
# bindkey "^N" down-line-or-history # 下
bindkey "^h" backward-char          # 左
bindkey "^l" forward-char           # 右
bindkey "^z" undo                   # Undo
bindkey '^a' copy-line # cmd に入力中の文字列をコピー

bindkey "^b" backward-word
bindkey "^f" forward-word

# バッファがない時のセミコロン => コロン {{{

function insert-semicolon() {
    if [[ -z "$LBUFFER" ]]; then
        LBUFFER+=":"
    else
        LBUFFER+=";"
    fi
}
zle -N insert-semicolon
bindkey ";" insert-semicolon

