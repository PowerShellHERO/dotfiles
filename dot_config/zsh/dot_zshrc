## git

gitautoadd() {
    local fn
    igt status --short | head -n 1 | sed 's/.../~\//' | read fn
    [[ "$fn" == "" ]] && green "not modified" && return 0

    git add fn
    git commit
}

## git_alias

alias gs=git\ status\ --short
alias ga=gitautoadd
alias gl="git log --name-status --date=format:'%Y-%m-%d %H:%M' --pretty=format:'%C(cyan)%cd %Cgreen[%cr]%n%s%n'"

